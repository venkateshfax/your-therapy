# Database Configuration
# For Vercel deployment, use Vercel Postgres
DATABASE_URL="your-vercel-postgres-url"
DIRECT_URL="your-vercel-postgres-direct-url"

# Authentication
NEXTAUTH_SECRET="your-unique-secret-key-minimum-32-characters"
NEXTAUTH_URL="https://your-app-name.vercel.app"

# OpenAI API (Optional - for advanced AI responses)
OPENAI_API_KEY="your-openai-api-key"

# Email Configuration (Optional - for follow-ups)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# Application Settings
APP_NAME="TherapyRoom"
APP_URL="https://your-app-name.vercel.app"